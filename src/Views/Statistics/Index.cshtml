@model PharmacyManager.DTOs.DashboardDto

@{
    ViewData["Title"] = "Personal Dashboard";
}

<div class="container py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="display-6 fw-bold text-dark border-bottom pb-2">
                <i class="bi bi-bar-chart-line-fill text-primary"></i> My Activity Dashboard
            </h2>
            <p class="text-muted">Welcome back, <strong>@User.Identity?.Name</strong>. Here is your performance overview.</p>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm bg-white">
                <div class="card-body">
                    <h6 class="card-subtitle mb-2 text-muted text-uppercase small">Pharmacy Inventory</h6>
                    <h2 class="card-title fw-bold">@Model.TotalMedicaments</h2>
                    <p class="card-text text-muted mb-0">Total drugs in stock</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm @(Model.LowStockCount > 0 ? "bg-warning-subtle" : "bg-white")">
                <div class="card-body">
                    <h6 class="card-subtitle mb-2 text-muted text-uppercase small">Inventory Alerts</h6>
                    <h2 class="card-title fw-bold @(Model.LowStockCount > 0 ? "text-danger" : "")">@Model.LowStockCount</h2>
                    <p class="card-text text-muted mb-0">Medicaments below 10 units</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm bg-primary text-white">
                <div class="card-body">
                    <h6 class="card-subtitle mb-2 text-white-50 text-uppercase small">My Avg. Sale Value</h6>
                    <h2 class="card-title fw-bold">@Model.AveragePrescriptionValue.ToString("C")</h2>
                    <p class="card-text text-white-50 mb-0">Based on your issued recipes</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-trophy text-warning me-2"></i>My Top 5 Best Sellers</h5>
                </div>
                <div class="card-body">
                    @if (Model.TopSellingMedicaments != null && Model.TopSellingMedicaments.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Medicine Name</th>
                                        <th class="text-end">Units Sold by Me</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var entry in Model.TopSellingMedicaments)
                                    {
                                        <tr>
                                            <td class="fw-semibold">@entry.Key</td>
                                            <td class="text-end">
                                                <span class="badge bg-dark rounded-pill px-3">@entry.Value</span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
                            <p class="mt-2 text-muted">You haven't sold any items yet.</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold">Quick Actions</h5>
                </div>
                <div class="card-body d-grid gap-3">
                    <a asp-controller="Prescriptions" asp-action="Create" class="btn btn-outline-primary btn-lg text-start">
                        <i class="bi bi-plus-circle me-2"></i> Issue New Recipe
                    </a>
                    <a asp-controller="Medicaments" asp-action="LowStock" class="btn btn-outline-warning btn-lg text-start">
                        <i class="bi bi-exclamation-triangle me-2"></i> View Low Stock
                    </a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-controller="Medicaments" asp-action="Create" class="btn btn-outline-dark btn-lg text-start">
                            <i class="bi bi-box-seam me-2"></i> Manage Inventory
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>