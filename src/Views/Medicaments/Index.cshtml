@model IEnumerable<PharmacyManager.DTOs.MedicamentDto>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-capsule"></i> Drug Inventory (Stocks)</h2>
    <div>
        <a asp-action="LowStock" class="btn btn-outline-warning">Low Stock Alerts</a>
        <a asp-action="Expired" class="btn btn-outline-danger">Expired Drugs</a>
        <a asp-action="Index" class="btn btn-outline-success">All Drugs</a>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Add New</a>
        }
    </div>
</div>

<table class="table table-hover shadow-sm bg-white">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Manufacturer</th>
            <th>Price</th>
            <th>Quantity</th>
            <th>Expiry Date</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr class="@(item.StockQuantity < 10 ? "table-warning" : "")">
                <td><strong>@item.Name</strong></td>
                <td>@item.ManufacturerName</td>
                <td>@item.Price.ToString("C")</td>
                <td>@item.StockQuantity</td>
                <td>@item.ExpiryDate.ToShortDateString()</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white"><i class="bi bi-eye"></i></a>
                    @if (User.IsInRole("Admin"))
                    {
                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this item?')"><i class="bi bi-trash"></i></button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>