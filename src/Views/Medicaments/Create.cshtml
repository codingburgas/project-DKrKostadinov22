@model PharmacyManager.DTOs.MedicamentDto

<div class="row justify-content-center">
    <div class="col-md-6 card p-4 shadow">
        <h3>Add New Medicament</h3>
        <form asp-action="Create">
            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label>Manufacturer</label>
                    <select asp-for="ManufacturerId" class="form-select" asp-items="ViewBag.Manufacturers"></select>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Price" class="form-label"></label>
                    <input asp-for="Price" type="number" step="0.01" class="form-control" />
                </div>
            </div>
            <div class="mb-3">
                <label>Categories (Hold Ctrl to select multiple)</label>
                <select asp-for="CategoryIds" class="form-select" asp-items="ViewBag.Categories" multiple></select>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label>Stock Quantity</label>
                    <input asp-for="StockQuantity" type="number" class="form-control" />
                </div>
                <div class="col-md-6 mb-3">
                    <label>Expiry Date</label>
                    <input asp-for="ExpiryDate" type="date" class="form-control" />
                </div>
            </div>
            <button type="submit" class="btn btn-success w-100">Save Medicament</button>
        </form>
    </div>
</div>