@model IEnumerable<PharmacyManager.DTOs.PrescriptionDto>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-receipt"></i> Digital Recipes</h2>
    <a asp-action="Create" class="btn btn-success"><i class="bi bi-plus-circle"></i> Issue New Recipe</a>
</div>

<div class="list-group shadow-sm">
    @foreach (var p in Model)
    {
        <a asp-action="Details" asp-route-id="@p.Id" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
            <div>
                <h5 class="mb-1">Patient: @p.PatientName</h5>
                <small class="text-muted">Dr. @p.DoctorName | Issued on: @p.IssuedDate.ToShortDateString()</small>
            </div>
            <span class="badge bg-primary rounded-pill p-2">@p.TotalValue.ToString("C")</span>
        </a>
    }
</div>