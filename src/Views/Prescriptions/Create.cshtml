@model PharmacyManager.DTOs.PrescriptionDto

<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <div class="card shadow border-0">
            <div class="card-header bg-success text-white py-3">
                <h4 class="mb-0"><i class="bi bi-receipt"></i> Issue New Digital Recipe</h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="All" class="text-danger"></div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="PatientName" class="form-label fw-bold">Patient Full Name</label>
                            <input asp-for="PatientName" class="form-control" placeholder="e.g. Ivan Ivanov" required />
                        </div>
                        <div class="form-group mb-3">
                            <label asp-for="PatientEgn" class="control-label">ЕГН на пациента</label>
                            <input asp-for="PatientEgn" class="form-control" placeholder="Въведете 10-цифрено ЕГН" />
                            <span asp-validation-for="PatientEgn" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DoctorName" class="form-label fw-bold">Prescribing Doctor</label>
                            <input asp-for="DoctorName" class="form-control" placeholder="e.g. Dr. Smith" required />
                        </div>
                    </div>

                    <hr />
                    <h5 class="mb-3 text-muted">Select Medicament</h5>
                    <div class="row mb-4 align-items-end">
                        <div class="col-md-8">
                            <label class="form-label fw-bold">Drug Name</label>
                            <select name="MedicamentId" class="form-select" asp-items="ViewBag.Medicaments">
                                <option value="">-- Choose from Inventory --</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Quantity</label>
                            <input type="number" name="Quantity" class="form-control" value="1" min="1" />
                        </div>
                    </div>

                    <div class="d-flex justify-content-between pt-3">
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                        <button type="submit" class="btn btn-success px-5">Complete & Save Recipe</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}